---
const { nivel = 1, cajon = 101 } = Astro.props;
---

<div class="p-6 bg-slate-900/50 backdrop-blur-xl rounded-[2.5rem] border border-white/10 shadow-2xl">
    <div class="flex bg-black/40 p-1.5 rounded-2xl mb-8 border border-white/5">
        <button id="mode-ia" type="button" class="flex-1 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all bg-indigo-600 text-white shadow-lg">
            🤖 IA Automática
        </button>
        <button id="mode-manual" type="button" class="flex-1 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all text-slate-500">
            ✍️ Manual
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="relative group">
            <label for="camera-input" class="flex flex-col items-center justify-center w-full h-80 border-2 border-dashed border-indigo-500/30 bg-indigo-500/5 rounded-[2.5rem] cursor-pointer hover:bg-indigo-500/10 hover:border-indigo-500/50 transition-all duration-300 overflow-hidden relative">
                <div id="preview-container" class="absolute inset-0 z-10 hidden bg-slate-900">
                    <img id="image-preview" class="w-full h-full object-cover" src="" />
                </div>
                
                <div id="upload-prompt" class="flex flex-col items-center justify-center pt-5 pb-6 text-center px-4">
                    <div class="w-20 h-20 mb-4 bg-indigo-600 rounded-full flex items-center justify-center shadow-2xl shadow-indigo-600/40 group-hover:scale-110 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                        </svg>
                    </div>
                    <p class="text-xl font-bold text-white tracking-tight">Escanear Vehículo</p>
                    <p class="text-sm text-slate-400 mt-1">Sube la foto para procesar</p>
                </div>
                <input id="camera-input" type="file" accept="image/*" capture="environment" class="hidden" />
                <div id="scan-line" class="absolute inset-0 z-20 bg-gradient-to-b from-transparent via-indigo-500/40 to-transparent h-12 w-full top-0 animate-scan hidden"></div>
            </label>
        </div>

        <form id="parking-form" class="space-y-4">
            <input type="hidden" id="usar_ia_val" value="true" />
            
            <div id="manual-fields" class="space-y-4 hidden">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] ml-2">Nivel</label>
                        <select id="manual-nivel" class="w-full bg-white/5 border border-white/10 p-4 rounded-2xl text-sm font-bold text-white outline-none focus:border-indigo-500">
                            <option value="1">Nivel 1</option>
                            <option value="2">Nivel 2</option>
                            <option value="3">Nivel 3</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] ml-2">Cajón Disponible</label>
                        <select id="manual-cajon" class="w-full bg-white/5 border border-white/10 p-4 rounded-2xl text-sm font-bold text-white outline-none focus:border-indigo-500">
                            </select>
                    </div>
                </div>

                <div>
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] ml-2">Placa (Manual)</label>
                    <input type="text" id="placa" class="w-full bg-white/5 border border-white/10 p-4 rounded-2xl text-white font-mono text-xl focus:border-indigo-500 outline-none uppercase" placeholder="ABC-123" />
                </div>
            </div>

            <div id="ia-info" class="p-6 bg-indigo-500/5 border border-indigo-500/20 rounded-[2rem]">
                <div class="flex items-start gap-3">
                    <span class="text-xl">✨</span>
                    <div>
                        <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-1">Modo IA Inteligente</p>
                        <p class="text-xs text-slate-400 leading-relaxed">Gemini asignará nivel y cajón automáticamente buscando espacios libres.</p>
                    </div>
                </div>
            </div>

            <button type="submit" id="btn-submit" class="w-full bg-indigo-600 py-6 rounded-[2rem] font-black text-white uppercase tracking-[0.2em] shadow-xl shadow-indigo-600/20 hover:bg-indigo-500 transition-all disabled:opacity-50">
                <span id="btn-text">Iniciar Clasificación</span>
            </button>
        </form>
    </div>
</div>

<script>
    function setupCamera() {
        const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8000";
        const modeIA = document.getElementById('mode-ia');
        const modeManual = document.getElementById('mode-manual');
        const manualFields = document.getElementById('manual-fields');
        const iaInfo = document.getElementById('ia-info');
        const usarIAVal = document.getElementById('usar_ia_val');
        const cameraInput = document.getElementById('camera-input');
        const imagePreview = document.getElementById('image-preview');
        const previewContainer = document.getElementById('preview-container');
        const uploadPrompt = document.getElementById('upload-prompt');
        const btnText = document.getElementById('btn-text');
        const btnSubmit = document.getElementById('btn-submit');
        const form = document.getElementById('parking-form');
        const selectNivel = document.getElementById('manual-nivel');
        const selectCajon = document.getElementById('manual-cajon');

        if (!modeIA || !modeManual) return;

        // Función para consultar cajones libres
        async function fetchDisponibilidad() {
            if (usarIAVal.value === "true") return;
            selectCajon.innerHTML = '<option>Cargando...</option>';
            try {
                const res = await fetch(`${API_URL}/disponibilidad/${selectNivel.value}`);
                const data = await res.json();
                selectCajon.innerHTML = '';
                if (data.libres && data.libres.length > 0) {
                    data.libres.forEach(c => {
                        const opt = document.createElement('option');
                        opt.value = c;
                        opt.textContent = `Espacio #${c}`;
                        selectCajon.appendChild(opt);
                    });
                    btnSubmit.disabled = false;
                } else {
                    selectCajon.innerHTML = '<option value="">NIVEL LLENO</option>';
                    btnSubmit.disabled = true;
                }
            } catch (e) {
                selectCajon.innerHTML = '<option>Error API</option>';
            }
        }

        modeIA.onclick = () => {
            usarIAVal.value = "true";
            modeIA.classList.add('bg-indigo-600', 'text-white');
            modeManual.classList.remove('bg-indigo-600', 'text-white');
            modeManual.classList.add('text-slate-500');
            manualFields.classList.add('hidden');
            iaInfo.classList.remove('hidden');
            btnText.innerText = "Iniciar Clasificación";
            btnSubmit.disabled = false;
        };

        modeManual.onclick = () => {
            usarIAVal.value = "false";
            modeManual.classList.add('bg-indigo-600', 'text-white');
            modeManual.classList.remove('text-slate-500');
            modeIA.classList.remove('bg-indigo-600', 'text-white');
            modeIA.classList.add('text-slate-500');
            manualFields.classList.remove('hidden');
            iaInfo.classList.add('hidden');
            btnText.innerText = "Registrar Manualmente";
            fetchDisponibilidad();
        };

        selectNivel.onchange = fetchDisponibilidad;

        cameraInput.onchange = (e) => {
            const file = e.target.files[0];
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
                previewContainer.classList.remove('hidden');
                uploadPrompt.classList.add('hidden');
            }
        };

        form.onsubmit = async (e) => {
            e.preventDefault();
            const file = cameraInput.files[0];
            if (!file) { alert("Sube una foto primero"); return; }

            btnSubmit.disabled = true;
            btnSubmit.innerText = "PROCESANDO...";
            const scanLine = document.getElementById('scan-line');
            if (usarIAVal.value === "true") scanLine.classList.remove('hidden');

            const fd = new FormData();
            fd.append('file', file);
            fd.append('usar_ia', usarIAVal.value);

            if (usarIAVal.value === "false") {
                fd.append('placa', document.getElementById('placa').value);
                fd.append('nivel', selectNivel.value);
                fd.append('cajon', selectCajon.value);
            }

            try {
                const res = await fetch(`${API_URL}/gestionar-vehiculo`, { method: 'POST', body: fd });
                const data = await res.json();
                if (res.ok) {
                    // REDIRECCIÓN ACTUALIZADA A /registro/
                    window.location.href = `/registro/${data.data.historial_id}`;
                } else {
                    alert("Error: " + data.detail);
                }
            } catch (err) {
                alert("Error de conexión");
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.innerText = usarIAVal.value === "true" ? "Iniciar Clasificación" : "Registrar Manualmente";
                scanLine.classList.add('hidden');
            }
        };
    }

    setupCamera();
    document.addEventListener('astro:after-swap', setupCamera);
    document.addEventListener('astro:page-load', setupCamera);
</script>

<style>
    @keyframes scan { from { top: -10%; } to { top: 100%; } }
    .animate-scan { animation: scan 2s linear infinite; }
</style>