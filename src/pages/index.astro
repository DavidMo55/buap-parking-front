---
import Layout from '../layouts/Layout.astro';
import ParkingCapture from '../components/CameraCapture.astro';

// En un flujo real, podrías recibir estos parámetros por URL si el usuario
// hace clic en un cajón específico del mapa antes de venir aquí.
const { searchParams } = Astro.url;
const nivelSeleccionado = parseInt(searchParams.get('nivel') || '1');
const cajonSeleccionado = parseInt(searchParams.get('cajon') || '101');
---

<Layout title="Nueva Clasificación">
    <div class="mt-4 mb-10">
        <div class="flex justify-between items-end">
            <div>
                <h2 class="text-4xl font-black text-white leading-none">
                    Hola, <br/><span class="text-indigo-500">Salieri</span>
                </h2>
                <p class="text-slate-400 mt-2 italic font-medium">Inicia una nueva gestión vehicular.</p>
            </div>
            <div class="hidden sm:block text-right">
                <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest block mb-1">Ubicación Actual</span>
                <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs font-bold text-indigo-400">
                    Nivel {nivelSeleccionado} • Cajón {cajonSeleccionado}
                </span>
            </div>
        </div>
    </div>

    <ParkingCapture nivel={nivelSeleccionado} cajon={cajonSeleccionado} />

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-6 bg-indigo-600/10 border border-indigo-500/20 rounded-3xl flex items-start gap-4">
            <div class="text-xl">🤖</div>
            <div>
                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-1">Tip de IA</p>
                <p class="text-xs text-indigo-300 font-medium leading-relaxed">
                    La IA Gemini 2.5 detecta marca, modelo y placa automáticamente. Asegúrate de tener buena iluminación.
                </p>
            </div>
        </div>

        <div class="p-6 bg-emerald-600/10 border border-emerald-500/20 rounded-3xl flex items-start gap-4">
            <div class="text-xl">☁️</div>
            <div>
                <p class="text-[10px] font-black text-emerald-400 uppercase tracking-widest mb-1">Almacenamiento</p>
              
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Animación sutil para la entrada de la página */
    main {
        animation: fadeIn 0.5s ease-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>