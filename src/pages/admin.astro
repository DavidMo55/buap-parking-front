---
import Layout from '../layouts/Layout.astro';

// Habilitamos SSR para métricas en tiempo real
export const prerender = false;

const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8000";

let stats = {
    ocupacionTotal: 0,
    vehiculosHoy: 0,
    tiempoPromedio: "N/A"
};

let niveles = [];

try {
    // 1. Obtenemos disponibilidad de todos los niveles (asumimos 3 niveles por ahora)
    const nivelesIds = [1, 2, 3];
    const fetchNiveles = nivelesIds.map(id => 
        fetch(`${API_BASE_URL}/disponibilidad/${id}`).then(r => r.json())
    );
    
    const resultados = await Promise.all(fetchNiveles);
    
    let totalOcupados = 0;
    const capacidadMaxima = 60; // 20 cajones * 3 niveles

    niveles = resultados.map(res => {
        const ocupados = 20 - res.libres.length;
        totalOcupados += ocupados;
        
        // Color dinámico según ocupación
        let color = 'bg-emerald-500';
        if (ocupados >= 15) color = 'bg-red-500';
        else if (ocupados >= 10) color = 'bg-yellow-500';

        return {
            id: res.nivel,
            ocupados: ocupados,
            total: 20,
            color: color
        };
    });

    stats.vehiculosHoy = totalOcupados;
    stats.ocupacionTotal = Math.round((totalOcupados / capacidadMaxima) * 100);

} catch (e) {
    console.error("Error cargando dashboard:", e);
}

const tiposOcupacion = [
    { etiqueta: 'Compactos', valor: 45, color: 'bg-indigo-500' },
    { etiqueta: 'Camionetas', valor: 30, color: 'bg-orange-500' },
    { etiqueta: 'Lujo', valor: 25, color: 'bg-emerald-500' },
];
---

<Layout title="Dashboard Administrativo">
    <div class="mb-8 flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-black text-white italic leading-none uppercase tracking-tighter">Estado General</h2>
            <p class="text-slate-400 text-sm mt-2 font-bold uppercase tracking-widest text-[10px]">Panel de Control en Tiempo Real</p>
        </div>
        <button onclick="window.location.reload()" class="p-3 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition-all text-white text-[10px] font-black uppercase tracking-widest">
            🔄 Actualizar
        </button>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-gradient-to-br from-indigo-600 to-blue-700 p-6 rounded-[2rem] shadow-xl shadow-indigo-600/20">
            <p class="text-white/70 text-[10px] font-black uppercase tracking-widest">Ocupación Total</p>
            <p class="text-4xl font-black text-white mt-1">{stats.ocupacionTotal}%</p>
        </div>
       
        <div class="bg-white/5 border border-white/10 p-6 rounded-[2rem]">
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Vehículos Hoy</p>
            <p class="text-4xl font-black text-white mt-1">{stats.vehiculosHoy}</p>
        </div>
        <div class="bg-white/5 border border-white/10 p-6 rounded-[2rem]">
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Estancia Prom.</p>
            <p class="text-4xl font-black text-white mt-1">2.4h</p>
        </div>
        <div class="bg-white/5 border border-white/10 p-6 rounded-[2rem]">
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Capacidad</p>
            <p class="text-4xl font-black text-white mt-1">60</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        
        <div class="lg:col-span-2 bg-white/5 border border-white/10 rounded-[2.5rem] p-8">
            <h3 class="font-bold text-xl mb-6 flex items-center gap-2 italic uppercase tracking-tighter text-white">
                <span class="w-2 h-6 bg-indigo-500 rounded-full shadow-[0_0_10px_rgba(99,102,241,0.5)]"></span>
                Capacidad por Nivel
            </h3>
            
            <div class="space-y-6">
                {niveles.map(n => (
                    <div class="relative group">
                        <a 
                            href={`/admin/nivel/${n.id}`} 
                            class="absolute inset-0 z-10"
                            aria-label={`Ver Nivel ${n.id}`}
                        ></a>
                        
                        <div class="relative z-0 transition-all duration-300 group-hover:translate-x-1">
                            <div class="flex justify-between items-end mb-2">
                                <span class="text-xs font-black text-white uppercase tracking-widest group-hover:text-indigo-400 transition-colors">
                                    NIVEL 0{n.id}
                                </span>
                                <span class="text-[10px] font-bold text-slate-500 group-hover:text-white transition-colors uppercase">
                                    {n.ocupados}/{n.total} Lugares Ocupados <span class="ml-2 opacity-0 group-hover:opacity-100 transition-all">Ver Mapa →</span>
                                </span>
                            </div>
                            <div class="w-full h-5 bg-black/40 rounded-full overflow-hidden border border-white/5 p-[3px] shadow-inner">
                                <div 
                                    class={`h-full ${n.color} rounded-full transition-all duration-1000 ease-out shadow-[0_0_15px_-3px_currentColor] group-hover:brightness-125`} 
                                    style={`width: ${(n.ocupados/n.total)*100}%`}
                                ></div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[2.5rem] p-8">
            <h3 class="font-bold text-xl mb-6 italic uppercase tracking-tighter text-white">Distribución</h3>
            <div class="space-y-5">
                {tiposOcupacion.map(t => (
                    <div class="flex items-center gap-4 group">
                        <div class={`w-12 h-12 rounded-2xl ${t.color} bg-opacity-10 border border-white/5 flex items-center justify-center text-xl group-hover:scale-110 transition-all`}>
                            {t.etiqueta === 'Compactos' ? '🚗' : t.etiqueta === 'Camionetas' ? '🛻' : '🏎️'}
                        </div>
                        <div class="flex-grow">
                            <div class="flex justify-between text-[10px] font-black uppercase mb-1">
                                <span class="text-slate-400 tracking-widest">{t.etiqueta}</span>
                                <span class="text-white tracking-tighter font-mono">{t.valor}%</span>
                            </div>
                            <div class="w-full h-1.5 bg-black/40 rounded-full overflow-hidden">
                                <div class={`h-full ${t.color} rounded-full shadow-[0_0_8px_currentColor]`} style={`width: ${t.valor}%`}></div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="mt-10 p-6 bg-indigo-500/5 rounded-[2rem] border border-indigo-500/10">
                <p class="text-[9px] text-indigo-300 font-black uppercase tracking-[0.2em] mb-2 italic underline">Protocolo de seguridad</p>
                <p class="text-[10px] text-slate-400 font-bold uppercase leading-relaxed tracking-tight">
                    El sistema bloquea automáticamente cajones ocupados en tiempo real tras la validación de salida.
                </p>
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Efecto de feedback al hacer click */
    a:active + div {
        transform: scale(0.98);
        opacity: 0.8;
    }
</style>